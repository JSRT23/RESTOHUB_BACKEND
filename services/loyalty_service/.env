# Django
DJANGO_SECRET_KEY=loyalty-secret-key-cambiar-en-produccion
DEBUG=True
ALLOWED_HOSTS=*
 
# Base de datos
POSTGRES_DB=loyalty_db
POSTGRES_USER=restohub
POSTGRES_PASSWORD=restohub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
 
# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=restohub
 
# Redis — caché de saldos de puntos
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# TTL en segundos para saldo de puntos por cliente (5 minutos)
REDIS_PUNTOS_TTL=300
 