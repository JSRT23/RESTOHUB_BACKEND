POSTGRES_DB=menu_db
POSTGRES_USER=restohub
POSTGRES_PASSWORD=restohub
POSTGRES_HOST=postgres
POSTGRES_PORT=5432



# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=restohub
RABBITMQ_PASSWORD=restohub
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=restohub
RABBITMQ_HEARTBEAT=120
RABBITMQ_BLOCKED_TIMEOUT=30
RABBITMQ_CONN_ATTEMPTS=5
RABBITMQ_RETRY_DELAY=3